<?xml version="1.0" encoding="UTF-8"?>
<!--
  Shared Logback configuration — include this in each service's logback-spring.xml:
  <include resource="logback-common.xml"/>
  MDC keys:
    traceId  → populated by Micrometer Tracing OTel bridge (per HTTP request)
    userId   → populated by MdcUserIdFilter / UserContextFilter
-->
<included>
  <conversionRule conversionWord="clr"
    converterClass="org.springframework.boot.logging.logback.ColorConverter"/>

  <appender name="CONSOLE" class="ch.qos.logback.core.ConsoleAppender">
    <encoder>
      <pattern>%d{yyyy-MM-dd HH:mm:ss.SSS} %clr(%-5level) [%15.15thread] %clr([traceId=%X{traceId:-none} userId=%X{userId:-anonymous}]){cyan} %clr(%-40.40logger{39}){magenta} - %msg%n</pattern>
      <charset>UTF-8</charset>
    </encoder>
  </appender>

  <logger name="org.springframework.boot.actuate.autoconfigure.tracing" level="INFO"/>
  <logger name="com.common.config" level="INFO"/>
  <logger name="org.springframework.web" level="INFO"/>
  <logger name="com.ecommerce" level="DEBUG"/>

  <root level="INFO">
    <appender-ref ref="CONSOLE"/>
  </root>
</included>
