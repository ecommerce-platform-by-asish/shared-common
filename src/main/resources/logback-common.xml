<?xml version="1.0" encoding="UTF-8"?>
<!--
  Shared Logback configuration — include this in each service's logback-spring.xml:
  <include resource="logback-common.xml"/>
  MDC keys:
    traceId  → populated by Micrometer Tracing OTel bridge (per HTTP request)
    userId   → populated by MdcUserIdFilter / UserContextFilter
-->
<included>
  <conversionRule conversionWord="clr"
    class="org.springframework.boot.logging.logback.ColorConverter"/>

  <conversionRule conversionWord="mdcClr"
    class="com.app.common.logging.MdcColorConverter"/>


  <appender name="CONSOLE" class="ch.qos.logback.core.ConsoleAppender">
    <encoder>
      <!-- Beautiful, color-coded, and well-spaced log format -->
      <pattern>%clr(%d{yyyy-MM-dd HH:mm:ss.SSS}){faint} %clr(%-5level) %clr(---){faint} %clr([%15.15thread]){faint} %clr([){faint}%clr(trace=){faint}%mdcClr{traceId} %clr(user=){faint}%mdcClr{userId}%clr(]){faint} %clr(%-40.40logger{39}){cyan} %clr(:){faint} %msg%n</pattern>
      <charset>UTF-8</charset>
    </encoder>
  </appender>

  <logger name="org.springframework.boot.actuate.autoconfigure.tracing" level="INFO"/>
  <logger name="com.common.config" level="INFO"/>
  <logger name="org.springframework.web" level="INFO"/>
  <logger name="com.ecommerce" level="DEBUG"/>

  <root level="INFO">
    <appender-ref ref="CONSOLE"/>
  </root>
</included>
